---
import App from '../components/App.vue';
import { pwaInfo } from 'virtual:pwa-info';
---

<html lang="es">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="apple-touch-icon" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<meta name="generator" content={Astro.generator} />
		<title>Trivia Seguridad - SGS</title>
		{ pwaInfo && <Fragment set:html={pwaInfo.webManifest.linkTag} /> }
		<script>
			import '../pwa.js';
		</script>
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;700;800&display=swap" rel="stylesheet">
		<link rel="preload" as="image" href="/assets/img/fondo.png" />
		<link rel="preload" as="image" href="/assets/img/logotipo.png" />
		<link rel="preload" as="image" href="/assets/img/supervisor-ok.png" />
		<link rel="preload" as="image" href="/assets/img/supervisor-pensando.png" />
		<link rel="preload" as="image" href="/assets/img/supervisor-diciendo.png" />
		<link rel="preload" as="image" href="/assets/img/supervisor-afirma.png" />
		<link rel="preload" as="image" href="/assets/img/supervisor-apunta.png" />
		<style lang="stylus">
			@import '../styles/normalize.styl'
			@import '../styles/common.styl'
			
			body
				background-color $sgs-azul-100
				height 100vh
				box-sizing border-box

			#pagina
				height 100vh
				width 100vw
				max-width 100%
				display flex
				flex-direction column
				justify-content center
				align-items stretch
				overflow hidden

				background-image linear-gradient(180deg, rgba(255, 255, 255, 1) 30%, rgba(255, 255, 255, 0) 50%), url(/assets/img/fondo.png)
				background-size auto, 100% auto
				background-repeat no-repeat
				background-position top center,  bottom center
				
		</style>
	</head>
	<body>
		<div id="pagina">
			<App client:load />
		</div>
	</body>
</html>
